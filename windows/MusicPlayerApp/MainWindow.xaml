<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MusicPlayerApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MusicPlayerApp.Views"
    Title="逆光音乐">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            PaneTitle="逆光音乐"
            PaneBackground="{ThemeResource NghSidebarBrush}"
            OpenPaneLength="220"
            CompactPaneLength="48"
            SelectionChanged="NavView_SelectionChanged"
            IsSettingsVisible="False">

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Search" ToolTipService.ToolTip="搜索">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE721;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock Text="搜索" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem Tag="Playlist" ToolTipService.ToolTip="播放列表">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock Text="播放列表" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem Tag="Favorites" ToolTipService.ToolTip="我喜欢">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEB51;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock Text="我喜欢" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem Tag="Lyrics" ToolTipService.ToolTip="歌词">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock Text="歌词" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem Tag="Leaderboard" ToolTipService.ToolTip="排行榜">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock Text="排行榜" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem Tag="LocalMusic" ToolTipService.ToolTip="本地音乐">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock Text="本地音乐" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem Tag="Nas" ToolTipService.ToolTip="NAS / 协议音源">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE943;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock Text="NAS" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="Settings" ToolTipService.ToolTip="设置">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock Text="设置" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Padding="0" Background="{ThemeResource NghBackgroundBrush}" />
        </NavigationView>

        <views:PlaybackBar Grid.Row="1" x:Name="BottomPlaybackBar" />
    </Grid>
</Window>
