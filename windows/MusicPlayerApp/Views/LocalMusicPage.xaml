<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MusicPlayerApp.Views.LocalMusicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MusicPlayerApp.Views">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="本地音乐"
            Style="{StaticResource NghPageTitleStyle}" />

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <Button Click="AddDirButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                    <TextBlock Text="添加扫描目录" />
                </StackPanel>
            </Button>
            <Button Click="RescanButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="重新扫描" />
                </StackPanel>
            </Button>
            <ProgressRing
                x:Name="ScanRing"
                IsActive="False"
                Width="22"
                Height="22" />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="12">
            <TextBlock
                x:Name="ProgressText"
                FontSize="13"
                Foreground="{ThemeResource NghTextSecondaryBrush}" />
        </StackPanel>

        <ListView
            Grid.Row="3"
            x:Name="LocalList"
            ItemsSource="{x:Bind Songs, Mode=OneWay}"
            SelectionMode="None"
            IsItemClickEnabled="True"
            ItemClick="LocalList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="views:SongViewModel">
                    <Grid ColumnSpacing="12" Padding="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            Glyph="&#xE8D6;"
                            FontSize="16"
                            Foreground="{ThemeResource NghPrimaryBrush}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource NghSongTitleStyle}" />
                            <TextBlock
                                Text="{x:Bind ArtistsText}"
                                Style="{StaticResource NghSongArtistStyle}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Column="2"
                            Text="{x:Bind DurationText}"
                            FontSize="12"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource NghTextSecondaryBrush}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
