<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MusicPlayerApp.Views.PlaylistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MusicPlayerApp.Views">

    <Grid Padding="24" RowSpacing="16" Background="{ThemeResource NghBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="当前播放列表"
            Style="{StaticResource NghPageTitleStyle}" />

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <Button Click="ClearButton_Click" Style="{StaticResource NghGhostButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    <TextBlock Text="清空列表" />
                </StackPanel>
            </Button>
            <TextBlock
                x:Name="CountText"
                VerticalAlignment="Center"
                FontSize="13"
                Foreground="{ThemeResource NghTextSecondaryBrush}" />
        </StackPanel>

        <ListView
            Grid.Row="2"
            x:Name="PlaylistView"
            ItemsSource="{x:Bind Songs, Mode=OneWay}"
            SelectionMode="Single"
            IsItemClickEnabled="True"
            ItemClick="PlaylistView_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="views:SongViewModel">
                    <Grid ColumnSpacing="12" Padding="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            Glyph="&#xE8D6;"
                            FontSize="16"
                            Foreground="{ThemeResource NghPrimaryBrush}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource NghSongTitleStyle}" />
                            <TextBlock
                                Text="{x:Bind ArtistsText}"
                                Style="{StaticResource NghSongArtistStyle}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                            <FontIcon
                                Glyph="&#xE768;"
                                FontSize="12"
                                Foreground="{ThemeResource NghPrimaryBrush}"
                                Visibility="{x:Bind IsCurrent, Mode=OneWay}" />
                            <Button
                                Tag="{x:Bind Id}"
                                Click="RemoveItem_Click"
                                Style="{StaticResource NghGhostButtonStyle}"
                                Padding="4">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
