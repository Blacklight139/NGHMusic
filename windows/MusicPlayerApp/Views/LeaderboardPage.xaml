<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MusicPlayerApp.Views.LeaderboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MusicPlayerApp.Models">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="排行榜"
            Style="{StaticResource NghPageTitleStyle}" />

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <ComboBox
                x:Name="SourceCombo"
                PlaceholderText="选择音源"
                Width="240"
                SelectionChanged="SourceCombo_SelectionChanged" />
            <ProgressRing
                x:Name="LoadingRing"
                IsActive="False"
                Width="22"
                Height="22" />
        </StackPanel>

        <ListView
            Grid.Row="2"
            x:Name="LeaderboardsList"
            ItemsSource="{x:Bind Leaderboards, Mode=OneWay}"
            SelectionMode="Single"
            IsItemClickEnabled="True"
            ItemClick="LeaderboardsList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Leaderboard">
                    <Expander
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE734;" FontSize="16" Foreground="{ThemeResource NghPrimaryBrush}" />
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource NghTextSecondaryBrush}"
                                    VerticalAlignment="Center">
                                    <Run Text="{x:Bind Songs.Count, Mode=OneWay}" />
                                    <Run Text=" 首" />
                                </TextBlock>
                            </StackPanel>
                        </Expander.Header>
                        <Expander.Content>
                            <ListView
                                ItemsSource="{x:Bind Songs}"
                                SelectionMode="None"
                                IsItemClickEnabled="True"
                                ItemClick="SongItem_Click">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Song">
                                        <Grid ColumnSpacing="8" Padding="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="&#xE8D6;" FontSize="12" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{x:Bind Title}"
                                                Style="{StaticResource NghSongTitleStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Expander.Content>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
