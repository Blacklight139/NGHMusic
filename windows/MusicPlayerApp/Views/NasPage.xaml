<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MusicPlayerApp.Views.NasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:MusicPlayerApp.Services"
    xmlns:views="using:MusicPlayerApp.Views">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="NAS / 协议音源"
            Style="{StaticResource NghPageTitleStyle}" />

        <Selector
            Grid.Row="1"
            x:Name="ModeSelector"
            SelectionChanged="ModeSelector_SelectionChanged">
            <SelectorItem Tag="feiniu">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE753;" FontSize="14" />
                    <TextBlock Text="飞牛 NAS" />
                </StackPanel>
            </SelectorItem>
            <SelectorItem Tag="protocol">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE943;" FontSize="14" />
                    <TextBlock Text="协议源浏览" />
                </StackPanel>
            </SelectorItem>
        </Selector>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="900">
                <!-- 飞牛 NAS 视图 -->
                <StackPanel x:Name="FeiniuPanel" Spacing="12">
                    <!-- 健康检查 -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon
                            x:Name="HealthIcon"
                            Glyph="&#xE9D9;"
                            FontSize="16"
                            Foreground="{ThemeResource NghTextSecondaryBrush}" />
                        <TextBlock x:Name="HealthText" Text="未检测" VerticalAlignment="Center" FontSize="13" />
                        <Button Click="HealthCheckButton_Click" Background="Transparent" BorderThickness="0" Padding="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                <TextBlock Text="健康检查" FontSize="13" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 登录表单 -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="飞牛登录" FontSize="16" FontWeight="SemiBold" />
                        <TextBox x:Name="BaseUrlBox" PlaceholderText="服务地址，如 https://nas.example.com" />
                        <TextBox x:Name="UsernameBox" PlaceholderText="用户名" />
                        <PasswordBox x:Name="PasswordBox" PlaceholderText="密码" />
                        <Button Click="LoginButton_Click" Style="{StaticResource NghPrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE77B;" FontSize="14" />
                                <TextBlock Text="登录" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 浏览区 -->
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="BackButton_Click" Background="Transparent" BorderThickness="0" Padding="4">
                                <FontIcon Glyph="&#xE72B;" FontSize="14" />
                            </Button>
                            <TextBlock x:Name="PathText" Text="/" VerticalAlignment="Center" FontSize="13" />
                            <Button Click="RefreshButton_Click" Background="Transparent" BorderThickness="0" Padding="4">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            </Button>
                        </StackPanel>
                        <ProgressRing x:Name="LoadingRing" IsActive="False" Width="22" Height="22" />
                        <ListView
                            x:Name="FilesList"
                            ItemsSource="{x:Bind FeiniuFiles, Mode=OneWay}"
                            SelectionMode="None"
                            IsItemClickEnabled="True"
                            ItemClick="FilesList_ItemClick"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource NghBorderBrush}"
                            CornerRadius="4"
                            MinHeight="200">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="views:NasFileItem">
                                    <Grid ColumnSpacing="12" Padding="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            Grid.Column="0"
                                            Glyph="{x:Bind IconGlyph}"
                                            FontSize="16"
                                            Foreground="{ThemeResource NghPrimaryBrush}" />
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Text="{x:Bind MetaText}"
                                                FontSize="11"
                                                Foreground="{ThemeResource NghTextSecondaryBrush}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{x:Bind SizeText}"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource NghTextSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>

                <!-- 协议源浏览视图 -->
                <StackPanel x:Name="ProtocolPanel" Spacing="12" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="协议源：" FontSize="14" VerticalAlignment="Center" />
                        <ComboBox x:Name="ProtocolSourceCombo" PlaceholderText="选择协议源" Width="280" SelectionChanged="ProtocolSourceCombo_SelectionChanged" />
                        <Button Click="RefreshSourcesButton_Click" Background="Transparent" BorderThickness="0" Padding="4">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="ProtocolHintText" Text="协议源添加 / 删除请在设置页管理" FontSize="11" Foreground="{ThemeResource NghTextSecondaryBrush}" />

                    <!-- 协议浏览路径 -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="ProtocolBackButton_Click" Background="Transparent" BorderThickness="0" Padding="4">
                            <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        </Button>
                        <TextBlock x:Name="ProtocolPathText" Text="/" VerticalAlignment="Center" FontSize="13" />
                        <Button Click="ProtocolRefreshButton_Click" Background="Transparent" BorderThickness="0" Padding="4">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    <ProgressRing x:Name="ProtocolLoadingRing" IsActive="False" Width="22" Height="22" />
                    <ListView
                        x:Name="ProtocolEntriesList"
                        ItemsSource="{x:Bind ProtocolEntries, Mode=OneWay}"
                        SelectionMode="None"
                        IsItemClickEnabled="True"
                        ItemClick="ProtocolEntriesList_ItemClick"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource NghBorderBrush}"
                        CornerRadius="4"
                        MinHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="views:ProtocolEntry">
                                <Grid ColumnSpacing="12" Padding="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Grid.Column="0"
                                        Glyph="{x:Bind IconGlyph}"
                                        FontSize="16"
                                        Foreground="{ThemeResource NghPrimaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="14" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
