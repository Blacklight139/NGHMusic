<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MusicPlayerApp.Views.PlaybackBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="80"
    Padding="16,8,16,8"
    Background="{ThemeResource NghSurfaceBrush}"
    BorderBrush="{ThemeResource NghBorderBrush}"
    BorderThickness="0,1,0,0">

    <Grid RowSpacing="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 进度条 -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="CurrentTimeText"
                Grid.Column="0"
                Text="00:00"
                FontSize="11"
                VerticalAlignment="Center"
                Foreground="{ThemeResource NghTextTertiaryBrush}" />
            <Slider
                x:Name="ProgressSlider"
                Grid.Column="1"
                Minimum="0"
                Maximum="1"
                Value="0"
                StepFrequency="1"
                TickFrequency="1"
                TickPlacement="None"
                ThumbToolTipVisibility="Never"
                ValueChanged="ProgressSlider_ValueChanged" />
            <TextBlock
                x:Name="DurationText"
                Grid.Column="2"
                Text="00:00"
                FontSize="11"
                VerticalAlignment="Center"
                Foreground="{ThemeResource NghTextTertiaryBrush}" />
        </Grid>

        <!-- 控制栏 -->
        <Grid Grid.Row="0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <!-- 当前歌曲信息 -->
            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                Spacing="12"
                VerticalAlignment="Center">
                <Border
                    Width="48"
                    Height="48"
                    CornerRadius="8"
                    Background="{ThemeResource NghPrimaryBrush}">
                    <FontIcon
                        Glyph="&#xE8D6;"
                        FontSize="24"
                        Foreground="White"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock
                        x:Name="SongTitleText"
                        Text="未播放"
                        Style="{StaticResource NghSongTitleStyle}"
                        MaxWidth="200" />
                    <TextBlock
                        x:Name="SongArtistText"
                        Text=""
                        Style="{StaticResource NghSongArtistStyle}"
                        MaxWidth="200" />
                </StackPanel>
            </StackPanel>

            <!-- 中央播放控制 -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <Button
                    x:Name="PrevButton"
                    Click="PrevButton_Click"
                    Style="{StaticResource NghGhostButtonStyle}"
                    ToolTipService.ToolTip="上一曲">
                    <FontIcon Glyph="&#xE892;" FontSize="18" />
                </Button>
                <Button
                    x:Name="PlayPauseButton"
                    Click="PlayPauseButton_Click"
                    Style="{StaticResource NghPrimaryButtonStyle}"
                    CornerRadius="20"
                    Padding="12"
                    ToolTipService.ToolTip="播放/暂停">
                    <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="20" />
                </Button>
                <Button
                    x:Name="NextButton"
                    Click="NextButton_Click"
                    Style="{StaticResource NghGhostButtonStyle}"
                    ToolTipService.ToolTip="下一曲">
                    <FontIcon Glyph="&#xE893;" FontSize="18" />
                </Button>
                <Button
                    x:Name="ModeButton"
                    Click="ModeButton_Click"
                    Style="{StaticResource NghGhostButtonStyle}"
                    ToolTipService.ToolTip="播放模式">
                    <FontIcon x:Name="ModeIcon" Glyph="&#xE1CE;" FontSize="16" />
                </Button>
            </StackPanel>

            <!-- 音量 -->
            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center"
                HorizontalAlignment="Right">
                <Button
                    x:Name="MuteButton"
                    Click="MuteButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    ToolTipService.ToolTip="静音">
                    <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" FontSize="14" Foreground="{ThemeResource NghTextSecondaryBrush}" />
                </Button>
                <Slider
                    x:Name="VolumeSlider"
                    Minimum="0"
                    Maximum="1"
                    Width="140"
                    StepFrequency="0.05"
                    ValueChanged="VolumeSlider_ValueChanged" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
