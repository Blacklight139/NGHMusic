<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MusicPlayerApp.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:MusicPlayerApp.Services">

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto" Background="{ThemeResource NghBackgroundBrush}">
        <StackPanel Spacing="20" MaxWidth="900">

            <TextBlock
                Text="设置"
                Style="{StaticResource NghPageTitleStyle}" />

            <!-- 音源导入（LXMusic 风格列表管理） -->
            <StackPanel Spacing="8">
                <TextBlock Text="音源管理" FontSize="18" FontWeight="SemiBold" />
                <TextBlock
                    Text="导入音源 JSON 文件（标准 / 社区格式自动适配）"
                    FontSize="12"
                    Foreground="{ThemeResource NghTextSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="ImportSourceButton_Click" Style="{StaticResource NghGhostButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="导入音源" />
                        </StackPanel>
                    </Button>
                    <Button Click="RefreshSourcesButton_Click" Style="{StaticResource NghGhostButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ListView
                    x:Name="SourcesList"
                    ItemsSource="{x:Bind Sources, Mode=OneWay}"
                    SelectionMode="None"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource NghBorderBrush}"
                    CornerRadius="4"
                    MinHeight="120">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="services:SourceInfo">
                            <Grid ColumnSpacing="12" Padding="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    Glyph="&#xE774;"
                                    FontSize="16"
                                    Foreground="{ThemeResource NghPrimaryBrush}" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{x:Bind Name}" Style="{StaticResource NghSongTitleStyle}" />
                                    <TextBlock
                                        Text="{x:Bind Id}"
                                        FontSize="11"
                                        Foreground="{ThemeResource NghTextSecondaryBrush}" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{x:Bind Priority}"
                                    FontSize="12"
                                    VerticalAlignment="Center" />
                                <ToggleSwitch
                                    Grid.Column="3"
                                    x:Name="EnabledToggle"
                                    IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                    Toggled="EnabledToggle_Toggled"
                                    Tag="{x:Bind Id}" />
                                <Button
                                    Grid.Column="4"
                                    Tag="{x:Bind Id}"
                                    Click="DeleteSourceButton_Click"
                                    Style="{StaticResource NghGhostButtonStyle}"
                                    Padding="4">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- 协议源管理 -->
            <StackPanel Spacing="8">
                <TextBlock Text="协议源（SMB / WebDAV / FTP / DLNA / NFS）" FontSize="18" FontWeight="SemiBold" />
                <ComboBox
                    x:Name="ProtocolCombo"
                    PlaceholderText="选择协议"
                    Width="200"
                    SelectedIndex="0">
                    <x:String>webdav</x:String>
                    <x:String>ftp</x:String>
                    <x:String>smb</x:String>
                    <x:String>nfs</x:String>
                    <x:String>dlna</x:String>
                </ComboBox>
                <TextBox
                    x:Name="ProtocolConfigBox"
                    PlaceholderText="协议配置 JSON（如 {&quot;auth&quot;:{&quot;base_url&quot;:&quot;https://...&quot;,&quot;username&quot;:&quot;...&quot;,&quot;password&quot;:&quot;...&quot;},&quot;root&quot;:&quot;/music&quot;}）"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    MinHeight="80"
                    MaxWidth="800" />
                <Button Click="AddProtocolButton_Click" Style="{StaticResource NghPrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="添加协议源" />
                    </StackPanel>
                </Button>
                <ListView
                    x:Name="ProtocolsList"
                    ItemsSource="{x:Bind ProtocolSources, Mode=OneWay}"
                    SelectionMode="None"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource NghBorderBrush}"
                    CornerRadius="4"
                    MinHeight="80">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="services:ProtocolSourceInfo">
                            <Grid ColumnSpacing="12" Padding="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE753;" FontSize="16" Foreground="{ThemeResource NghPrimaryBrush}" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Style="{StaticResource NghSongTitleStyle}">
                                        <Run Text="{x:Bind Protocol}" />
                                        <Run Text=" · " />
                                        <Run Text="{x:Bind Id}" />
                                    </TextBlock>
                                    <TextBlock Text="{x:Bind Root}" FontSize="11" Foreground="{ThemeResource NghTextSecondaryBrush}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="2"
                                    Tag="{x:Bind Id}"
                                    Click="DeleteProtocolButton_Click"
                                    Style="{StaticResource NghGhostButtonStyle}"
                                    Padding="4">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- 缓存管理 -->
            <StackPanel Spacing="8">
                <TextBlock Text="缓存管理" FontSize="18" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="CacheStatsText" FontSize="13" VerticalAlignment="Center" Foreground="{ThemeResource NghTextSecondaryBrush}" />
                    <Button Click="ClearCacheButton_Click" Style="{StaticResource NghGhostButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            <TextBlock Text="清空缓存" />
                        </StackPanel>
                    </Button>
                    <Button Click="RefreshCacheButton_Click" Style="{StaticResource NghGhostButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="4">
                <TextBlock Text="关于" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="逆光音乐 (NGHMusic) · Windows 客户端" FontSize="13" Foreground="{ThemeResource NghTextSecondaryBrush}" />
                <TextBlock x:Name="CoreVersionText" FontSize="12" Foreground="{ThemeResource NghTextTertiaryBrush}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
