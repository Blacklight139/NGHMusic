<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MusicPlayerApp.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MusicPlayerApp.Views">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="我喜欢"
            FontSize="28"
            FontWeight="SemiBold" />

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <Button Click="PlayAllButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                    <TextBlock Text="全部播放" />
                </StackPanel>
            </Button>
            <TextBlock
                x:Name="CountText"
                VerticalAlignment="Center"
                FontSize="13"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ListView
            Grid.Row="2"
            x:Name="FavoritesList"
            ItemsSource="{x:Bind Songs, Mode=OneWay}"
            SelectionMode="None"
            IsItemClickEnabled="True"
            ItemClick="FavoritesList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="views:SongViewModel">
                    <Grid ColumnSpacing="12" Padding="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            Glyph="&#xEB51;"
                            FontSize="16"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Bind Title}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Text="{x:Bind ArtistsText}"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button
                            Grid.Column="2"
                            Tag="{x:Bind Id}"
                            Click="RemoveFavorite_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
