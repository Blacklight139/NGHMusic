<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MusicPlayerApp.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MusicPlayerApp.Models"
    xmlns:views="using:MusicPlayerApp.Views">

    <Grid Padding="24" RowSpacing="16" Background="{ThemeResource NghBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="搜索音乐"
            Style="{StaticResource NghPageTitleStyle}" />

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <AutoSuggestBox
                x:Name="KeywordBox"
                PlaceholderText="输入歌曲 / 歌手 / 专辑关键词..."
                Width="420"
                QueryIcon="Find"
                KeyDown="KeywordBox_KeyDown" />
            <Button
                x:Name="SearchButton"
                Content="搜索"
                Style="{StaticResource NghPrimaryButtonStyle}"
                Click="SearchButton_Click" />
            <ProgressRing
                x:Name="LoadingRing"
                IsActive="False"
                Width="24"
                Height="24" />
        </StackPanel>

        <ListView
            Grid.Row="2"
            x:Name="ResultsList"
            ItemsSource="{x:Bind Songs, Mode=OneWay}"
            SelectionMode="None"
            IsItemClickEnabled="True"
            ItemClick="ResultsList_ItemClick"
            DoubleTapped="ResultsList_DoubleTapped">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="views:SongViewModel">
                    <Grid ColumnSpacing="12" Padding="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            Glyph="&#xE8D6;"
                            FontSize="20"
                            Foreground="{ThemeResource NghPrimaryBrush}" />
                        <StackPanel
                            Grid.Column="1"
                            Spacing="2">
                            <TextBlock
                                Text="{x:Bind Title}"
                                Style="{StaticResource NghSongTitleStyle}" />
                            <TextBlock
                                Text="{x:Bind ArtistsText}"
                                Style="{StaticResource NghSongArtistStyle}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                            <FontIcon
                                Glyph="&#xE768;"
                                FontSize="12"
                                Foreground="{ThemeResource NghPrimaryBrush}"
                                Visibility="{x:Bind IsCurrent, Mode=OneWay}" />
                            <TextBlock
                                Text="{x:Bind DurationText}"
                                FontSize="12"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource NghTextTertiaryBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Spacing="12">
            <Button
                x:Name="PrevPageButton"
                Content="上一页"
                Style="{StaticResource NghGhostButtonStyle}"
                Click="PrevPageButton_Click" />
            <TextBlock
                x:Name="PageInfo"
                VerticalAlignment="Center"
                FontSize="13"
                Foreground="{ThemeResource NghTextSecondaryBrush}" />
            <Button
                x:Name="NextPageButton"
                Content="下一页"
                Style="{StaticResource NghGhostButtonStyle}"
                Click="NextPageButton_Click" />
        </StackPanel>
    </Grid>
</Page>
