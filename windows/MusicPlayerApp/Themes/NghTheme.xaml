<?xml version="1.0" encoding="utf-8"?>
<!-- 逆光音乐 / NGHWindows 设计系统 token（豆包风格），与 iOS/Android/HarmonyOS 对齐。 -->
<!-- 配色：主色 #4E6EF2、背景 #F7F8FA、表面 #FFFFFF、文本 #1F1F1F/#6B6B6B/#999999、边框 #EDEEF0。 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 主色 -->
    <Color x:Key="NghPrimaryColor">#4E6EF2</Color>
    <Color x:Key="NghPrimaryHoverColor">#3D5AE0</Color>
    <SolidColorBrush x:Key="NghPrimaryBrush" Color="{StaticResource NghPrimaryColor}" />
    <SolidColorBrush x:Key="NghPrimaryHoverBrush" Color="{StaticResource NghPrimaryHoverColor}" />
    <SolidColorBrush x:Key="NghPrimarySoftBrush" Color="#144E6EF2" />

    <!-- 背景 / 表面 -->
    <Color x:Key="NghBackgroundColor">#F7F8FA</Color>
    <Color x:Key="NghSurfaceColor">#FFFFFF</Color>
    <Color x:Key="NghSurfaceAltColor">#F0F2F5</Color>
    <SolidColorBrush x:Key="NghBackgroundBrush" Color="{StaticResource NghBackgroundColor}" />
    <SolidColorBrush x:Key="NghSurfaceBrush" Color="{StaticResource NghSurfaceColor}" />
    <SolidColorBrush x:Key="NghSurfaceAltBrush" Color="{StaticResource NghSurfaceAltColor}" />
    <SolidColorBrush x:Key="NghSidebarBrush" Color="#FFFFFF" />

    <!-- 文本 -->
    <Color x:Key="NghTextPrimaryColor">#1F1F1F</Color>
    <Color x:Key="NghTextSecondaryColor">#6B6B6B</Color>
    <Color x:Key="NghTextTertiaryColor">#999999</Color>
    <SolidColorBrush x:Key="NghTextPrimaryBrush" Color="{StaticResource NghTextPrimaryColor}" />
    <SolidColorBrush x:Key="NghTextSecondaryBrush" Color="{StaticResource NghTextSecondaryColor}" />
    <SolidColorBrush x:Key="NghTextTertiaryBrush" Color="{StaticResource NghTextTertiaryColor}" />

    <!-- 边框 -->
    <Color x:Key="NghBorderColor">#EDEEF0</Color>
    <Color x:Key="NghBorderSoftColor">#F5F6F8</Color>
    <SolidColorBrush x:Key="NghBorderBrush" Color="{StaticResource NghBorderColor}" />
    <SolidColorBrush x:Key="NghBorderSoftBrush" Color="{StaticResource NghBorderSoftColor}" />

    <!-- 语义色 -->
    <SolidColorBrush x:Key="NghDangerBrush" Color="#F5483B" />
    <SolidColorBrush x:Key="NghSuccessBrush" Color="#00B96B" />
    <SolidColorBrush x:Key="NghWarningBrush" Color="#FA8C16" />

    <!-- 尺寸 token -->
    <x:Double x:Key="NghRadiusSm">8</x:Double>
    <x:Double x:Key="NghRadiusMd">12</x:Double>
    <x:Double x:Key="NghRadiusLg">16</x:Double>

    <x:Double x:Key="NghSpacing1">4</x:Double>
    <x:Double x:Key="NghSpacing2">8</x:Double>
    <x:Double x:Key="NghSpacing3">12</x:Double>
    <x:Double x:Key="NghSpacing4">16</x:Double>
    <x:Double x:Key="NghSpacing5">20</x:Double>
    <x:Double x:Key="NghSpacing6">24</x:Double>
    <x:Double x:Key="NghSpacing7">32</x:Double>
    <x:Double x:Key="NghSpacing8">40</x:Double>

    <!-- 品牌按钮样式 -->
    <Style x:Key="NghPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource NghPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <!-- 透明按钮样式（播放控制等） -->
    <Style x:Key="NghGhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <!-- 页面标题样式 -->
    <Style x:Key="NghPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource NghTextPrimaryBrush}" />
    </Style>

    <!-- 副标题样式 -->
    <Style x:Key="NghSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource NghTextSecondaryBrush}" />
    </Style>

    <!-- 歌曲标题样式 -->
    <Style x:Key="NghSongTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource NghTextPrimaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- 歌曲艺术家样式 -->
    <Style x:Key="NghSongArtistStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource NghTextSecondaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
</ResourceDictionary>
